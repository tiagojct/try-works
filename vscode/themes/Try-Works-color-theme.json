{
  "name": "Try-Works",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "keyword": "#c9651d",
    "string": "#86a87f",
    "number": "#a487ba",
    "function": "#5f93b0",
    "method": "#5f93b0",
    "function.defaultLibrary": "#5f97a0",
    "class": "#5f97a0",
    "type": "#5f97a0",
    "struct": "#5f97a0",
    "interface": "#5f97a0",
    "enum": "#5f97a0",
    "namespace": "#d06a52",
    "decorator": "#d06a52",
    "macro": "#a487ba",
    "variable": "#f1efe9",
    "parameter": "#cdd2d3",
    "variable.readonly": "#a487ba",
    "operator": "#aeb6b8",
    "comment": {
      "foreground": "#97a0a4",
      "fontStyle": "italic"
    }
  },
  "colors": {
    "editor.background": "#12161b",
    "editor.foreground": "#f1efe9",
    "editorLineNumber.foreground": "#606c72",
    "editorLineNumber.activeForeground": "#97a0a4",
    "editorCursor.foreground": "#c9651d",
    "editor.selectionBackground": "#2c495366",
    "editor.lineHighlightBackground": "#1b2127",
    "editor.findMatchHighlightBackground": "#e0832a33",
    "editorBracketHighlight.foreground1": "#8fb6bd",
    "editorBracketHighlight.foreground2": "#c9651d",
    "editorBracketHighlight.foreground3": "#a487ba",
    "editorBracketHighlight.foreground4": "#86a87f",
    "editorBracketHighlight.foreground5": "#5f93b0",
    "editorBracketHighlight.foreground6": "#d06a52",
    "editorError.foreground": "#d06a52",
    "editorWarning.foreground": "#c9651d",
    "editorInfo.foreground": "#5f93b0",
    "focusBorder": "#c9651d",
    "button.background": "#c9651d",
    "button.foreground": "#11151a",
    "button.hoverBackground": "#e0832a",
    "badge.background": "#c9651d",
    "badge.foreground": "#11151a",
    "input.background": "#1b2127",
    "input.border": "#2c3640",
    "inputOption.activeBorder": "#c9651d",
    "list.activeSelectionBackground": "#232b32",
    "list.highlightForeground": "#c9651d",
    "list.hoverBackground": "#1d242b",
    "sideBar.background": "#1b2127",
    "sideBar.foreground": "#cdd2d3",
    "sideBar.border": "#2c3640",
    "sideBarTitle.foreground": "#97a0a4",
    "sideBarSectionHeader.background": "#12161b",
    "activityBar.background": "#12161b",
    "activityBar.foreground": "#f1efe9",
    "activityBarBadge.background": "#c9651d",
    "activityBarBadge.foreground": "#11151a",
    "statusBar.background": "#1b2127",
    "statusBar.foreground": "#97a0a4",
    "statusBar.border": "#2c3640",
    "statusBar.debuggingBackground": "#c9651d",
    "statusBar.debuggingForeground": "#11151a",
    "titleBar.activeBackground": "#12161b",
    "titleBar.activeForeground": "#f1efe9",
    "titleBar.border": "#2c3640",
    "tab.activeBackground": "#12161b",
    "tab.inactiveBackground": "#1b2127",
    "tab.activeForeground": "#f1efe9",
    "tab.inactiveForeground": "#97a0a4",
    "tab.activeBorderTop": "#c9651d",
    "tab.border": "#2c3640",
    "editorGroupHeader.tabsBackground": "#1b2127",
    "panel.background": "#12161b",
    "panel.border": "#2c3640",
    "panelTitle.activeBorder": "#c9651d",
    "terminal.background": "#12161b",
    "terminal.foreground": "#f1efe9",
    "terminalCursor.foreground": "#c9651d",
    "gitDecoration.modifiedResourceForeground": "#c9651d",
    "gitDecoration.untrackedResourceForeground": "#86a87f",
    "gitDecoration.deletedResourceForeground": "#d06a52",
    "textLink.foreground": "#5f93b0",
    "textLink.activeForeground": "#e0832a",
    "terminal.ansiBlack": "#1b2127",
    "terminal.ansiRed": "#c05a3a",
    "terminal.ansiGreen": "#6f8f6a",
    "terminal.ansiYellow": "#c9651d",
    "terminal.ansiBlue": "#46708a",
    "terminal.ansiMagenta": "#8a6f9e",
    "terminal.ansiCyan": "#5f97a0",
    "terminal.ansiWhite": "#c9ccce",
    "terminal.ansiBrightBlack": "#3a4754",
    "terminal.ansiBrightRed": "#d06a52",
    "terminal.ansiBrightGreen": "#86a87f",
    "terminal.ansiBrightYellow": "#e0832a",
    "terminal.ansiBrightBlue": "#5f93b0",
    "terminal.ansiBrightMagenta": "#a487ba",
    "terminal.ansiBrightCyan": "#8fb6bd",
    "terminal.ansiBrightWhite": "#f1efe9"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#97a0a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.other",
        "keyword.operator.arrow.r",
        "keyword.operator.assignment.r"
      ],
      "settings": {
        "foreground": "#c9651d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string",
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#86a87f"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.python"
      ],
      "settings": {
        "foreground": "#a487ba"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "entity.name.function.r"
      ],
      "settings": {
        "foreground": "#5f93b0"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "storage.type.class.python",
        "entity.name.type.class.python",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#5f97a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.definition.decorator",
        "entity.name.function.decorator.python",
        "entity.name.tag",
        "keyword.other.namespace",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#d06a52"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable",
        "variable.other.r"
      ],
      "settings": {
        "foreground": "#f1efe9"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable.parameter.python"
      ],
      "settings": {
        "foreground": "#cdd2d3"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.r"
      ],
      "settings": {
        "foreground": "#aeb6b8"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8a9296"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#c9651d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f1efe9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f1efe9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#5f93b0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#5f97a0"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#d06a52"
      }
    }
  ]
}
